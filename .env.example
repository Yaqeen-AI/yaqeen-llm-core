# Yaqeen AI Multi-Agent RAG - Environment Configuration

# ===============
# Core API Keys
# ===============
# Gemini is used for the Agentic workflows (routing, re-writing, aggregation, generation)
GEMINI_API_KEY=your_gemini_api_key_here
# Fallback (optional) if using legacy configs
GOOGLE_API_KEY=your_google_api_key_here

# Jina AI is used for Embeddings (v3) and Reranking (v3 / v2)
JINA_API_KEY=your_jina_api_key_here

# ===============
# Vector Database (Qdrant)
# ===============

# Quran RAG (Web/Cloud)
QURAN_QDRANT_URL=https://your-quran-qdrant-instance.gcp.qdrant.io
QURAN_QDRANT_API_KEY=your_quran_api_key_here
QURAN_COLLECTION_NAME=YourQuranCOLLECTIONNAME

# Hadith RAG (Web/Cloud)
HADITH_QDRANT_URL=https://your-hadith-qdrant-instance.gcp.qdrant.io
HADITH_QDRANT_API_KEY=your_hadith_api_key_here
HADITH_COLLECTION_NAME=YourHadithCollectionName

# Fiqh RAG (Web/Cloud)
FIQH_QDRANT_URL=https://your-fiqh-qdrant-instance.gcp.qdrant.io
FIQH_QDRANT_API_KEY=your_fiqh_api_key_here
FIQH_COLLECTION_NAME=YourFiqhCOLLECTIONNAME

# ===============
# Caching (Redis)
# ===============
# Redis url for semantic caching
REDIS_URL=REDIS_URL_NAME
# Threshold for semantic cache similarity hits
SEMANTIC_CACHE_THRESHOLD=0.86

# ===============
# Models Config
# ===============
GEMINI_AGENT_MODEL=gemini-3.1-flash-lite
JINA_EMBEDDING_MODEL=jina-embeddings-v3
JINA_RERANKER_MODEL=jina-reranker-v3

# ===============
# BM25 Config (Local)
# ===============
BM25_USE_GPU=False
