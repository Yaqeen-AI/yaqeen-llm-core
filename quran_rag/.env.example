# ============================================================
# YaqeenAI — Environment Configuration
# ============================================================
# Copy this to .env and adjust values

# --- Quran API ---
QURAN_API_BASE_URL=https://api.quranhub.com/v1
QURAN_DEFAULT_EDITION=quran-uthmani

# --- Chroma ---
CHROMA_PERSIST_DIRECTORY=data/quran_full
CHROMA_COLLECTION_NAME=quran_tafsir_ar

# --- Embedding Model ---
# Full-Quran production defaults
EMBEDDING_MODEL_NAME=jinaai/jina-embeddings-v3
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=16
EMBEDDING_MAX_LENGTH=1024
EMBEDDING_TASK_PASSAGE=retrieval.passage
EMBEDDING_TASK_QUERY=retrieval.query

# --- Reranker Model ---
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3

# --- Retrieval Settings ---
SEMANTIC_TOP_K=30
BM25_TOP_K=30
RRF_TOP_K=20
RERANK_TOP_K=5
RRF_K=60
RETRIEVAL_CONTEXT_WINDOW=1

# --- Collection Names ---
QURAN_COLLECTION_NAME=quran_tafsir_ar

# --- Generation ---
GENERATION_PROVIDER=google_genai
GENERATION_MODEL_NAME=gemma-3-27b-it
GENERATION_TEMPERATURE=0.2
GENERATION_TOP_P=0.9
GENERATION_MAX_OUTPUT_TOKENS=1024
GOOGLE_API_KEY=

# --- Server ---
HOST=0.0.0.0
PORT=8000
RELOAD=true
