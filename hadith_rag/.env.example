# ============================================================
# YaqeenAI — Hadith RAG System Environment Variables
# ============================================================
# Copy this file to .env and fill in your API keys.

# --- Jina AI (for query-time embedding via REST API) ---
# Get your key at: https://jina.ai/ → API Keys
JINA_API_KEY=your_jina_api_key_here

# --- Google Gemini (for generation) ---
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Groq (for generation) --- FREE
# Get your key at: https://console.groq.com/
# Completely free with fast inference
# GROQ_API_KEY=gsk_your_groq_api_key_here

# --- Vector DB (Qdrant) ---
VECTOR_DB_TYPE=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=hadiths
QDRANT_TIMEOUT_SECONDS=30

# --- ChromaDB legacy fallback / migration export only ---
CHROMA_PERSIST_DIR=./chroma_db/hadith_chroma_db
CHROMA_COLLECTION_NAME=hadiths

# --- Jina Embedding Settings ---
JINA_EMBEDDING_MODEL=jina-embeddings-v3
JINA_EMBEDDING_DIM=1024

# --- Jina Reranker ---
JINA_RERANK_API_URL=https://api.jina.ai/v1/rerank
RERANKER_MODEL=jina-reranker-v3

# --- Retrieval Settings ---
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5

# --- Gemini Settings ---
GEMINI_MODEL=gemma-3-27b-it


# --- Groq Settings --- FREE
# Options: llama-3.3-70b-versatile, llama-3.1-70b-versatile, mixtral-8x7b-32768
# GROQ_MODEL=llama-3.3-70b-versatile
