# ============================================================
# Ignore everything EXCEPT the Query Router folder
# ============================================================

# Ignore everything at root
/*

# But keep the Query Router folder
!/Query Router/

# Within Query Router, still ignore these:
Query Router/**/.env
Query Router/__pycache__/
Query Router/**/__pycache__/
Query Router/**/*.py[cod]

# Keep .gitignore itself
!.gitignore
